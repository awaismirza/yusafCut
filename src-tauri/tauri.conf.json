{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scribe",
  "version": "3.1.0",
  "identifier": "dev.scribe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Scribe",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' asset: data:; media-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**/*",
          "$VIDEO/**/*",
          "$DOWNLOAD/**/*",
          "$DESKTOP/**/*",
          "$DOCUMENT/**/*",
          "$TEMP/**/*",
          "/Volumes/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Video",
    "shortDescription": "Local-first text-based video editor",
    "longDescription": "Scribe lets you edit talking-head video by editing its transcript. Everything runs 100% on your Mac.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "frameworks": []
    },
    "externalBin": [
      "binaries/whisper-cli",
      "binaries/whisperkit-cli",
      "binaries/ffmpeg",
      "binaries/ffprobe",
      "binaries/mlx-sidecar"
    ]
  },
  "plugins": {}
}
