# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Node
node_modules/
dist/
dist-ssr/
*.local

# Vite
.vite/
vite.config.ts.timestamp-*.mjs

# Build artefacts
src-tauri/target/
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
!src-tauri/binaries/README.md
!src-tauri/binaries/fetch.sh
# mlx-sidecar: the dev shell-script launcher (~1 KB) is committed.
# The PyInstaller binary (~60 MB) generated by `npm run build:production`
# must never be committed. build-production.sh sets skip-worktree on it.
!src-tauri/binaries/mlx-sidecar-aarch64-apple-darwin
# whisperkit-cli: the stub shell script (~200 B) is committed.
# The real Mach-O binary (~6 MB) built by `npm run whisperkit:build`
# must never be committed. build-whisperkit-cli.sh sets skip-worktree on it.
!src-tauri/binaries/whisperkit-cli-aarch64-apple-darwin

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test
coverage/

# Tauri
.tauri/
*.dmg
*.app
*.app.tar.gz

# Sidecar build outputs + venv
sidecars/**/dist/
sidecars/**/build/
sidecars/**/.venv/
sidecars/**/__pycache__/
sidecars/**/*.egg-info/

# Models (downloaded at runtime)
models/
*.bin
*.mlmodelc
*.mlmodelc.zip

# Mac App Store — provisioning profile and Xcode archive output (never commit)
src-tauri/*.provisionprofile
*.xcarchive

# Misc
.env
.env.local
